output HEADLESS-1 {
    pos 0,0
    mode 3000x1500@75Hz
    scale 1.5
}

output WL-1 {
    pos 0,0
    mode 1200x700
    scale 1.5
}

input type:keyboard {
    xkb_layout us
}

focus_follows_mouse no
focus_on_window_activation focus
default_border none
for_window [app_id="^org.jetbrains.desktop.linux.tests$"] floating enable, move position 0 0
for_window [app_id="^org.jetbrains.desktop.linux.tests.TestApp.*"] floating enable, move position 300 0
swaybg_command -
swaynag_command -
